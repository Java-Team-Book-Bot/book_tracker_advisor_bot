# Telegram
TELEGRAM_BOT_TOKEN=
BOT_USERNAME=BookAdvisorBot

# GigaChat
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Google Books (optional, public API works without key but with quota)
GOOGLE_BOOKS_API_KEY=

# MongoDB
MONGO_URI=mongodb://mongo:27017/booktracker

# Admin HTTP API
ADMIN_API_KEY=change-me

# ZeroMQ reminders
ZMQ_REMINDER_ENDPOINT=tcp://127.0.0.1:5555
REMINDER_TZ=Europe/Moscow

# HTTP server
HTTP_PORT=8080
